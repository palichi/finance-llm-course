# =============================================
# 한국투자증권 OpenAPI (모의투자)
# 발급: https://apiportal.koreainvestment.com
# =============================================
KIS_APP_KEY=여기에_App_Key_입력
KIS_APP_SECRET=여기에_App_Secret_입력
KIS_ACCOUNT_NO=12345678

# =============================================
# OpenAI API
# 발급: https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=sk-여기에_OpenAI_Key_입력

# =============================================
# 금융위원회 공공데이터 API
# 발급: https://www.data.go.kr → "주식시세" 검색
# =============================================
FSS_API_KEY=여기에_공공데이터_Key_입력
